{
    int N,res=0,c,N1;
    printf("Enter N: ");
    scanf("%d", &N);
    N1=N;
    while(N>0)
    {
        c=N%10;
        res=res*10+c;
        N/=10;
    }   
    printf("  %d",res);
    if(res==N1)
    {
         printf(" The number is palindrome ");
    }
    else
    {
         printf(" The number is not palindrome ");
    }
